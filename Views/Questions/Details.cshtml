@model ExamMeAI.Models.Question

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Question</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.QuestionId</dd>

        <dt class="col-sm-2">Text</dt>
        <dd class="col-sm-10">@Model.QuestionText</dd>

        <dt class="col-sm-2">User</dt>
        <dd class="col-sm-10">@Model.User</dd>

        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.TitleId</dd>

        <dt class="col-sm-2">Domain</dt>
        <dd class="col-sm-10">@Model.DomainId</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.QuestionId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>