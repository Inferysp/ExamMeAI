@{
    ViewData["Title"] = "Demo Page";
}

<div class="text-center container">
    <h1 class="display-4">@ViewData["Title"]</h1>
    <Form id="DemoForm" asp-controller="Demo" method="post" class="fs-1">
        <Button type="button" id="DemoBtn" class="btn btn-success">Make OpenAI responce to console Test!</Button>
    </Form>

    <div class="mt-4">
        <h2>Response from OpenAI:</h2>
        <pre id="OpenAIResponce" class="fs-5">--wartość startowa--</pre>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById("DemoBtn").addEventListener("click", function (event) {
        event.preventDefault(); // blokuje przeładowanie strony

        console.log("Button clicked, fetching OpenAI response...");

        fetch('/Demo/PostOpenAiResponceOnBtnClick', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.text())
        .then(data => {
            console.log("Response from server:", data);
            document.getElementById("OpenAIResponce").textContent = data;
        })
        .catch(error => console.error("Error:", error));
    });
</script>
}
